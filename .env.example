# Server Manager configuration template.
# Copy this file to ".env" and adjust the values as needed.
# Environment variables loaded here (or exported in the shell) take precedence
# over command line options when set and non-empty.

# ------------------------------------------------------------------------------
# Required
# ------------------------------------------------------------------------------
# Command used to start the server (leave empty to require it via CLI/env).
START_COMMAND=

# ------------------------------------------------------------------------------
# Optional hooks
# ------------------------------------------------------------------------------
# Command executed before starting the server (empty by default).
BEFORE_COMMAND=
# Command executed after starting the server (empty by default).
AFTER_COMMAND=

# ------------------------------------------------------------------------------
# Logging configuration (all optional, defaults shown)
# ------------------------------------------------------------------------------
# Directory where log files are stored. Relative paths are anchored to the
# script directory; absolute paths are used as-is.
LOG_DIR=logs

# Log file name placed inside LOG_DIR.
LOG_FILE_NAME=server.log

# Maximum number of rotated backup files to keep.
LOG_MAX_BACKUPS=2
