#!/bin/sh
# Server Manager - background service management script
# Compatible with both sh and bash interpreters.

# ------------------------------------------------------------------------------
# Bootstrap: resolve script directory and load .env if present.
# ------------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Load KEY=VALUE entries from a .env file and export them literally.
# Empty lines and comment lines (starting with '#') are skipped. A single
# pair of surrounding single or double quotes around the value is stripped.
# Leading/trailing whitespace is trimmed. Values are treated as literal text
# (no shell expansion).
load_env() {
    _env_file="$1"
    _dq='"'
    _sq="'"
    [ -f "${_env_file}" ] || return 0
    while IFS= read -r _line || [ -n "${_line}" ]; do
        case "${_line}" in
            ''|'#'*) continue ;;
        esac
        case "${_line}" in
            *=*) ;;
            *) continue ;;
        esac
        _key="${_line%%=*}"
        _val="${_line#*=}"
        # Trim leading whitespace from key/value.
        _key="${_key#"${_key%%[! ]*}"}"
        _val="${_val#"${_val%%[! ]*}"}"
        # Trim trailing whitespace from key/value.
        _key="${_key%"${_key##*[! ]}"}"
        _val="${_val%"${_val##*[! ]}"}"
        case "${_val}" in
            "${_dq}"*"${_dq}") _val="${_val#${_dq}}"; _val="${_val%${_dq}}" ;;
            "${_sq}"*"${_sq}") _val="${_val#${_sq}}"; _val="${_val%${_sq}}" ;;
        esac
        case "${_key}" in
            ''|*[!A-Za-z0-9_]*) continue ;;
            [0-9]*) continue ;;
        esac
        export "${_key}=${_val}"
    done < "${_env_file}"
}

load_env "${SCRIPT_DIR}/.env"

# ------------------------------------------------------------------------------
# Configuration with defaults (log config defaults are mandatory).
# ------------------------------------------------------------------------------
LOG_DIR="${LOG_DIR:-logs}"
# Anchor a relative LOG_DIR to the script directory for stable behavior.
case "${LOG_DIR}" in
    /*) ;;
    *)  LOG_DIR="${SCRIPT_DIR}/${LOG_DIR}" ;;
esac

LOG_FILE_NAME="${LOG_FILE_NAME:-server.log}"
LOG_MAX_BACKUPS="${LOG_MAX_BACKUPS:-2}"
PID_FILE="${SCRIPT_DIR}/server.pid"
LOCK_FILE="${SCRIPT_DIR}/.server.lock"
LOG_FILE="${LOG_DIR}/${LOG_FILE_NAME}"

# Capture environment values (highest priority, may come from .env or shell).
ENV_START_COMMAND="${START_COMMAND:-}"
ENV_BEFORE_COMMAND="${BEFORE_COMMAND:-}"
ENV_AFTER_COMMAND="${AFTER_COMMAND:-}"

# Placeholders filled by command line parsing.
CLI_START_COMMAND=""
CLI_BEFORE_COMMAND=""
CLI_AFTER_COMMAND=""

# Parse start/restart command line options into the CLI_* placeholders.
# Consumes arguments and leaves none; use after a 'shift'.
parse_start_options() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -c|--command) CLI_START_COMMAND="$2";  shift 2 ;;
            -b|--before)  CLI_BEFORE_COMMAND="$2"; shift 2 ;;
            -a|--after)   CLI_AFTER_COMMAND="$2";  shift 2 ;;
            *) print_error "Unknown option: $1"; show_usage; exit 1 ;;
        esac
    done
}

# ------------------------------------------------------------------------------
# Output helpers: unified English text, portable printf-based coloring.
# ------------------------------------------------------------------------------
COLOR_RED='\033[0;31m'
COLOR_GREEN='\033[0;32m'
COLOR_YELLOW='\033[0;33m'
COLOR_RESET='\033[0m'

print_info()    { printf '%s\n' "$*"; }
print_success() { printf "${COLOR_GREEN}%s${COLOR_RESET}\n" "$*"; }
print_error()   { printf "${COLOR_RED}%s${COLOR_RESET}\n" "$*" >&2; }
print_warn()    { printf "${COLOR_YELLOW}%s${COLOR_RESET}\n" "$*"; }

# ------------------------------------------------------------------------------
# Common helpers (shared logic, no duplication).
# ------------------------------------------------------------------------------

# Resolve final command values: environment overrides command line.
resolve_commands() {
    START_COMMAND="${ENV_START_COMMAND:-${CLI_START_COMMAND}}"
    BEFORE_COMMAND="${ENV_BEFORE_COMMAND:-${CLI_BEFORE_COMMAND}}"
    AFTER_COMMAND="${ENV_AFTER_COMMAND:-${CLI_AFTER_COMMAND}}"
}

# Ensure the log directory exists.
ensure_log_dir() {
    [ -d "${LOG_DIR}" ] || mkdir -p "${LOG_DIR}"
}

# Return 0 if the server is running, 1 otherwise; clean up stale pid file.
check_pid() {
    [ -f "${PID_FILE}" ] || return 1
    pid="$(cat "${PID_FILE}" 2>/dev/null)"
    [ -n "${pid}" ] || { rm -f "${PID_FILE}"; return 1; }
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    fi
    rm -f "${PID_FILE}"
    return 1
}

# Echo the recorded pid (empty if none).
get_pid() {
    [ -f "${PID_FILE}" ] && cat "${PID_FILE}" 2>/dev/null
}

# Acquire the start lock atomically. Returns 0 on success, 1 if another
# instance already holds the lock or a server is already running.
# The lock file is created first; if a server is already running we
# release it and back off. This prevents the TOCTOU race where two
# invocations pass the pid check before either creates the lock.
acquire_start_lock() {
    # Atomic create using noclobber. If this fails, another start is in
    # progress (or a stale lock exists from a crashed previous start).
    if ! ( set -C; : > "${LOCK_FILE}" ) 2>/dev/null; then
        return 1
    fi
    # Now that we hold the lock, verify no server is actually running.
    if check_pid; then
        release_start_lock
        return 1
    fi
    return 0
}

# Release the start lock.
release_start_lock() {
    rm -f "${LOCK_FILE}"
}

# Rotate log files, keeping at most LOG_MAX_BACKUPS backups.
rotate_log() {
    [ -f "${LOG_FILE}" ] || return 0
    rm -f "${LOG_FILE}.bak.${LOG_MAX_BACKUPS}"
    i=$((LOG_MAX_BACKUPS - 1))
    while [ "${i}" -ge 1 ]; do
        if [ -f "${LOG_FILE}.bak.${i}" ]; then
            mv "${LOG_FILE}.bak.${i}" "${LOG_FILE}.bak.$((i + 1))"
        fi
        i=$((i - 1))
    done
    mv "${LOG_FILE}" "${LOG_FILE}.bak.1"
}

# Run a hook command when non-empty, sending output to the log file.
run_hook() {
    [ -n "$1" ] || return 0
    eval "$1" >> "${LOG_FILE}" 2>&1
}

# ------------------------------------------------------------------------------
# Commands
# ------------------------------------------------------------------------------

do_start() {
    resolve_commands

    if [ -z "${START_COMMAND}" ]; then
        print_error "Error: START_COMMAND is not defined"
        print_info "Example:"
        print_info "  export START_COMMAND=\"python3 /path/to/your/server.py\""
        print_info "  Or: $0 start --command \"python3 /path/to/your/server.py\""
        return 1
    fi

    if ! acquire_start_lock; then
        print_error "Error: Server is already running or another start is in progress"
        return 1
    fi

    ensure_log_dir
    rotate_log
    : > "${LOG_FILE}"

    run_hook "${BEFORE_COMMAND}"

    # Detach from the controlling terminal so the process survives SSH
    # disconnect. Wrap the command in "sh -c 'exec ...'" so that spaces and
    # quotes inside START_COMMAND are preserved correctly, and use setsid to
    # create a new session without a controlling terminal. The inner exec
    # replaces the shell with the actual service so $! is the service PID.
    # Falls back to nohup where setsid is unavailable.
    if command -v setsid >/dev/null 2>&1; then
        setsid sh -c "exec ${START_COMMAND}" >> "${LOG_FILE}" 2>&1 < /dev/null &
    else
        nohup sh -c "exec ${START_COMMAND}" >> "${LOG_FILE}" 2>&1 < /dev/null &
    fi
    child_pid=$!

    sleep 1
    if ! kill -0 "${child_pid}" 2>/dev/null; then
        release_start_lock
        print_error "Error: Failed to start server"
        return 1
    fi

    echo "${child_pid}" > "${PID_FILE}"
    release_start_lock

    run_hook "${AFTER_COMMAND}"

    print_success "Server started successfully with PID ${child_pid}"
    print_info "Log file: ${LOG_FILE}"
    return 0
}

# Stop the server with a given signal, polling up to max_wait seconds.
# Returns 0 on success, 1 if the process did not stop in time.
stop_server() {
    signal="$1"
    max_wait="$2"

    if ! check_pid; then
        print_info "Server is not running"
        rm -f "${PID_FILE}" 2>/dev/null
        return 0
    fi

    pid="$(get_pid)"
    if [ "${signal}" = "TERM" ]; then
        print_info "Stopping server (PID: ${pid})..."
    else
        print_info "Forcefully shutting down server (PID: ${pid})..."
    fi

    kill -"${signal}" "${pid}" 2>/dev/null

    count=0
    while kill -0 "${pid}" 2>/dev/null && [ "${count}" -lt "${max_wait}" ]; do
        sleep 1
        count=$((count + 1))
        printf '.'
    done
    printf '\n'

    if kill -0 "${pid}" 2>/dev/null; then
        print_warn "Warning: Server did not stop, still running"
        return 1
    fi

    rm -f "${PID_FILE}"
    if [ "${signal}" = "TERM" ]; then
        print_success "Server stopped successfully"
    else
        print_success "Server forcefully stopped"
    fi
    return 0
}

do_stop()     { stop_server TERM 30; }
do_shutdown() { stop_server KILL 1; }

do_status() {
    if check_pid; then
        printf "Server is ${COLOR_GREEN}running${COLOR_RESET} (PID: $(get_pid))\n"
        exit 0
    fi
    printf "Server is ${COLOR_RED}stopped${COLOR_RESET}\n"
    exit 1
}

do_log() {
    if [ ! -f "${LOG_FILE}" ]; then
        print_error "Log file does not exist: ${LOG_FILE}"
        exit 1
    fi

    lines=""
    follow=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -n) lines="$2"; shift 2 ;;
            -f) follow="1"; shift ;;
            *)  shift ;;
        esac
    done

    if [ -n "${follow}" ] && [ -n "${lines}" ]; then
        tail -n "${lines}" -f "${LOG_FILE}"
    elif [ -n "${follow}" ]; then
        tail -f "${LOG_FILE}"
    elif [ -n "${lines}" ]; then
        tail -n "${lines}" "${LOG_FILE}"
    else
        tail "${LOG_FILE}"
    fi
}

do_restart() {
    print_info "Restarting server..."
    if check_pid; then
        do_stop || return 1
        sleep 1
    else
        print_info "Server is not running"
        rm -f "${PID_FILE}" 2>/dev/null
    fi
    do_start
}

do_clean() {
    if check_pid; then
        print_error "Error: Server is running (PID: $(get_pid)). Stop server before cleaning logs."
        exit 1
    fi

    if [ ! -d "${LOG_DIR}" ]; then
        print_info "No log files to clean"
        exit 0
    fi

    count=0
    for f in "${LOG_DIR}"/server*.log; do
        [ -f "$f" ] && count=$((count + 1))
    done

    if [ "${count}" -eq 0 ]; then
        print_info "No log files to clean"
        exit 0
    fi

    rm -f "${LOG_DIR}"/server*.log
    print_info "Cleaned ${count} log file(s)"
}

show_usage() {
    cat <<EOF
Usage: $0 {start|stop|shutdown|status|logs|restart|clean}

Commands:
  start    Start the server in background
  stop     Gracefully stop the server (SIGTERM)
  shutdown Forcefully stop the server (SIGKILL)
  status   Show server status
  logs     View server logs (supports -n NUM and -f)
  restart  Restart the server (accepts the same options as start)
  clean    Clean all log files

Start/Restart options:
  -c, --command CMD   Set the command to start the server
  -b, --before CMD    Set command to run before starting server
  -a, --after CMD     Set command to run after starting server

Note: Environment variables (START_COMMAND, BEFORE_COMMAND, AFTER_COMMAND)
      loaded from .env or the shell take precedence over command line options
      when set and non-empty.
EOF
}

# ------------------------------------------------------------------------------
# Argument dispatch
# ------------------------------------------------------------------------------
case "$1" in
    start)
        shift
        parse_start_options "$@"
        do_start || exit 1
        ;;
    stop)     do_stop || exit 1 ;;
    shutdown) do_shutdown || exit 1 ;;
    status)   do_status ;;
    logs)     shift; do_log "$@" ;;
    restart)
        shift
        parse_start_options "$@"
        do_restart || exit 1
        ;;
    clean)    do_clean ;;
    *)        show_usage; exit 1 ;;
esac
